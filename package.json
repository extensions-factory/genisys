{
  "name": "@risotech/genisys",
  "version": "0.0.0",
  "description": "Interactive CLI provisioner — cookiecutter-style wizard with nested recipes for system setup",
  "type": "module",
  "bin": {
    "genisys": "./dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "dev": "tsx src/cli.ts",
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "test": "echo \"no tests yet\" && exit 0",
    "lint": "echo \"no lint yet\" && exit 0",
    "prepublishOnly": "pnpm run build",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "pnpm run build && changeset publish"
  },
  "keywords": [
    "cli",
    "provisioner",
    "scaffold",
    "cookiecutter",
    "setup",
    "wizard"
  ],
  "author": "",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/extensions-factory/genisys.git"
  },
  "bugs": {
    "url": "https://github.com/extensions-factory/genisys/issues"
  },
  "homepage": "https://github.com/extensions-factory/genisys#readme",
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "@inquirer/prompts": "^5.3.0",
    "chalk": "^5.3.0",
    "ora": "^8.0.1"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.0",
    "@types/node": "^20.14.0",
    "tsx": "^4.16.0",
    "typescript": "^5.5.0"
  }
}
